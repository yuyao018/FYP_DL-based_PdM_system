# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key-or-service-role-key

# Email Notification Configuration
# Option 1: Resend (recommended for deployment — works on all platforms)
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_SENDER=Engine Alerts <alerts@yourdomain.com>
EMAIL_RECIPIENTS=engineer1@company.com,engineer2@company.com
DASHBOARD_URL=http://localhost:8050

# Option 2: SMTP (fallback for local development)
EMAIL_PASSWORD=your-gmail-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Groq API (primary LLM for Degradation Analysis explanations — free tier)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
